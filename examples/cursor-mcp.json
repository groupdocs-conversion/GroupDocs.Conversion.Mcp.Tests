{
  "mcpServers": {
    "groupdocs-conversion": {
      "command": "dnx",
      "args": ["GroupDocs.Conversion.Mcp@26.7.0", "--yes"],
      "env": {
        "GROUPDOCS_MCP_STORAGE_PATH": "/absolute/path/to/documents",
        "GROUPDOCS_LICENSE_PATH": "/absolute/path/to/GroupDocs.Total.lic"
      }
    }
  }
}
